# ==========================================
# AI Foundation Journey - .gitignore
# ==========================================

# ------------------------------------------
# Python
# ------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ------------------------------------------
# Virtual Environments
# ------------------------------------------
ai_data/
.venv/
venv/
env/
ENV/

# ------------------------------------------
# Jupyter Notebook
# ------------------------------------------
.ipynb_checkpoints/

# ------------------------------------------
# VS Code
# ------------------------------------------
.vscode/

# ------------------------------------------
# Python Build Files
# ------------------------------------------
build/
dist/
*.egg-info/
*.egg

# ------------------------------------------
# Test & Coverage
# ------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# ------------------------------------------
# Type Checkers
# ------------------------------------------
.mypy_cache/
.pytype/
.ruff_cache/

# ------------------------------------------
# Logs
# ------------------------------------------
*.log

# ------------------------------------------
# Operating System Files
# ------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------
# Environment Variables
# ------------------------------------------
.env
.env.*

# ------------------------------------------
# Temporary Files
# ------------------------------------------
tempCodeRunnerFile.py

# ------------------------------------------
# IDE Settings
# ------------------------------------------
.idea/

# ------------------------------------------
# Notebook Runtime
# ------------------------------------------
profile_default/
ipython_config.py

# ------------------------------------------
# Streamlit Secrets
# ------------------------------------------
.streamlit/secrets.toml